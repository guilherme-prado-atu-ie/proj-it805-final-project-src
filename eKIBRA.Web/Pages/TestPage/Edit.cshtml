@page
@model eKIBRA.Web.Pages.TestPage.EditModel

@{
    ViewData["Title"] = "Edit";
}

<partial name="_ValidationAuthenticationCheckPartial" />

<h4>Edit a Test Session</h4>

<partial name="_ValidationStatusMessagePartial" for="StatusMessage" />

@{ if (string.IsNullOrWhiteSpace(Model.Input?.Id)) return; }

<p>
    <a asp-page="./Create">Create New</a> |
    <a asp-page="./Details" asp-route-id="@Model.Input.Id">Details</a> |
    <a asp-page="./Delete" asp-route-id="@Model.Input.Id">Delete</a> |
    <a asp-page="./Index">Back to List</a>
</p>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <input type="hidden" asp-for="Input.Id" />
            <input type="hidden" asp-for="Input.DeckId" />
            @*<div class="form-floating mb-3">
                <input asp-for="Input.Id" class="form-control" placeholder="" readonly></input>
                <label asp-for="Input.Id" class="control-label"></label>
                <span asp-validation-for="Input.Id" class="text-danger"></span>
            </div>*@
            <div class="form-floating mb-3">
                <input asp-for="Input.Title" class="form-control" placeholder=""/>
                <label asp-for="Input.Title" class="control-label"></label>
                <span asp-validation-for="Input.Title" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <textarea asp-for="Input.Description" class="form-control" placeholder=""></textarea>
                <label asp-for="Input.Description" class="control-label"></label>
                <span asp-validation-for="Input.Description" class="text-danger"></span>
            </div>
            
            <div class="form-floating mb-3">
                <input asp-for="Input.Status" class="form-control" placeholder="" readonly></input>
                <label asp-for="Input.Status" class="control-label"></label>
                <span asp-validation-for="Input.Status" class="text-danger"></span>
                
            </div>
            @*<div class="form-floating mb-3">
                <input asp-for="Input.DeckId" class="form-control" placeholder="" readonly></input>
                <label asp-for="Input.DeckId" class="control-label"></label>
                <span asp-validation-for="Input.DeckId" class="text-danger"></span>
            </div>*@
            <div class="form-floating mb-3">
                <input asp-for="Input.DeckTitle" class="form-control" placeholder="" readonly></input>
                <label asp-for="Input.DeckTitle" class="control-label"></label>
                <span asp-validation-for="Input.DeckTitle" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Created" class="form-control" autocomplete="off" placeholder="" 
                       value="@Model.Input.Created.ToString("yyyy-MM-ddTHH:mm")" readonly />
                <label asp-for="Input.Created"></label>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Modified" class="form-control" autocomplete="off" placeholder="" 
                       value="@Model.Input.Modified?.ToString("yyyy-MM-ddTHH:mm")" readonly />
                <label asp-for="Input.Modified"></label>
            </div>
            <button id="save-book-button" type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
