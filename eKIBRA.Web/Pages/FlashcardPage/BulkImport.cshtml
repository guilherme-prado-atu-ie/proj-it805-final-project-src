@page
@model eKIBRA.Web.Pages.FlashcardPage.BulkImportModel
@{
    ViewData["Title"] = "Bulk Import Flashcard";
}

<h4>Import Flashcard via CSV File</h4>
<p>
    <a asp-page="./Create">Back to Create</a> |
    <a asp-page="Index">Back to Flashcard List</a>
</p>
<hr/>

<partial name="_ValidationStatusMessagePartial" for="StatusMessage"/>

<style>
    .svg-icon {
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .svg-icon:hover {
        transform: scale(1.1);
    }
    
    .bi-exclamation-triangle-fill {
        color: #ffc107; /* Bootstrap warning yellow */
        fill: currentColor;
    }
</style>


<div class="row">
    <div class="col-md-6">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <label class="form-label">1. Select Deck:</label>
            <div class="form-floating mb-3">
                <input asp-for="Input.DeckTitle" class="form-control" autocomplete="off" placeholder=""/>
                <label asp-for="Input.DeckTitle"></label>
                <select multiple asp-for="Input.DeckTitle" class="form-select h-auto"
                        style="display: none;" placeholder=""></select>
                <input asp-for="Input.DeckId" type="hidden"/>
                <span asp-validation-for="Input.DeckTitle" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.CsvFile" class="form-label"></label>
                <input asp-for="Input.CsvFile" type="file" class="form-control" accept=".csv"/>
                <span asp-validation-for="Input.CsvFile" class="text-danger"></span>
                <div class="form-text">Supported format: .csv (Max 10MB)</div>
            </div>
            <div class="d-flex gap-2">
                <a href="~/csv/BulkImportViewModelLayout.csv" class="btn btn-secondary" download>Download Sample CSV</a>
                <button type="submit" asp-page-handler="Import" class="btn btn-success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                         class="bi bi-upload" viewBox="0 0 16 16">
                        <path
                            d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/>
                        <path
                            d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708z"/>
                    </svg>
                    Upload & Preview CSV
                </button>
                <button type="submit" asp-page-handler="Save" class="btn btn-primary" disabled="@(!Model.IsDataLoaded)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                         class="bi bi-save" viewBox="0 0 16 16">
                        <path
                            d="M2 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H9.5a1 1 0 0 0-1 1v7.293l2.646-2.647a.5.5 0 0 1 .708.708l-3.5 3.5a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L7.5 9.293V2a2 2 0 0 1 2-2H14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h2.5a.5.5 0 0 1 0 1z"/>
                    </svg>
                    Save to Deck
                </button>
            </div>
        </form>
    </div>
</div>
<br/>
@if (Model.Input.Flashcards != null && Model.Input.Flashcards.Any())
{
    <hr/>
    <h5>Preview of CSV Data (@Model.Input.Flashcards.Count() records)</h5>
    <div class="row mt-3">
        <div class="col-12">
            <div class="table-responsive" style="overflow-y: auto;">
                @if (Model.Input.Flashcards.Any(f => f.IsDuplicated))
                {
                    <div class="alert alert-warning" role="alert">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-triangle-fill svg-icon" viewBox="0 0 16 16">
                            <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                        </svg>
                        <strong>Warning:</strong> Some flashcards have duplicate questions and will not be saved.
                    </div>
                }
                <table class="table table-striped table-hover table-sm">
                    <thead class="table-light sticky-top">
                    <tr>
                        <th>#</th>
                        <th>Question</th>
                        <th>Answer</th>
                        <th>Incorrect One</th>
                        <th>Incorrect Two</th>
                        <th>Incorrect Three</th>
                        <th>Incorrect Four</th>
                    </tr>
                    </thead>
                    <tbody>
                    @{ int rowNum = 1; }
                    @foreach (var item in Model.Input.Flashcards)
                    {
                        <tr>
                            <td>@(rowNum++)</td>
                            <td>
                                @if (item.IsDuplicated)
                                {
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-exclamation-triangle-fill svg-icon" viewBox="0 0 16 16">
                                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                                    </svg>
                                }
                                @Html.DisplayFor(modelItem => item.Question)
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.Answer)</td>
                            <td>@Html.DisplayFor(modelItem => item.IncorrectOne)</td>
                            <td>@Html.DisplayFor(modelItem => item.IncorrectTwo)</td>
                            <td>@Html.DisplayFor(modelItem => item.IncorrectThree)</td>
                            <td>@Html.DisplayFor(modelItem => item.IncorrectFour)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        eKIBRA.addAutoCompleteEvents({
            inputAspFor: "Input.DeckTitle", inputAspForHiddenId: "Input.DeckId", handlerName: "SearchDeck"
        });

        document.addEventListener('DOMContentLoaded', function () {
            const csvFileInput = document.getElementById('@Html.IdFor(model => model.Input.CsvFile)');
            if (csvFileInput) {
                csvFileInput.addEventListener('change', function (e) {
                    const fileName = e.target.files[0]?.name;
                    if (fileName && !fileName.toLowerCase().endsWith('.csv')) {
                        e.target.value = '';
                    }
                });
            }
        });
    </script>
}