@page
@model eKIBRA.Web.Pages.FlashcardPage.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<partial name="_ValidationAuthenticationCheckPartial" />

<h4>Flashcard Details</h4>

<partial name="_ValidationStatusMessagePartial" for="StatusMessage" />

@{ if (string.IsNullOrWhiteSpace(Model.Input?.Id)) return; }

<p>
    <a asp-page="./Create">Create New</a> |
    <a asp-page="./Edit" asp-route-id="@Model.Input.Id">Edit</a> |
    <a asp-page="./Delete" asp-route-id="@Model.Input.Id">Delete</a> |
    <a asp-page="./Index">Back to List</a>
</p>
<hr />
<div>
    <dl class="row">
        <dt class="col-sm-2">
            Linked Deck
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Input.LinkedDeck!.Title)
        </dd>
        <dt class="col-sm-2">
            Question
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Input.Question)
        </dd>
        <dt class="col-sm-2">
            Answer
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Input.Answer)
        </dd>
        <dt class="col-sm-2">
            Created
        </dt>
        <dd class="col-sm-10">
            @Model.Input.Created.ToString("dd.MMM.yyyy HH:mm")
        </dd>
        <dt class="col-sm-2">
            Modified
        </dt>
        <dd class="col-sm-10">
            @Model.Input.Modified?.ToString("dd.MMM.yyyy HH:mm")
        </dd>
        <dt class="col-sm-2">
            Id
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Input.Id)
        </dd>
    </dl>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
            <tr>
                <th>
                    #
                </th>
                <th>
                    Incorrects Answers
                </th>
            </tr>
            </thead>
            <tbody class="table-group-divider">
            @for (var index = 0; index < Model.Input.Incorrects.Count; index++)
            {
                var num = index + 1;
                var item = Model.Input.Incorrects[index];
                <tr>
                    <td>
                        @num
                    </td>
                    <td>
                        @Html.DisplayFor(model => item)
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
