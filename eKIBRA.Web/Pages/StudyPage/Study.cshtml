@page
@model eKIBRA.Web.Pages.StudyPage.StudyModel

@{
    ViewData["Title"] = "Study";
}
<partial name="_ValidationAuthenticationCheckPartial" xmlns="http://www.w3.org/1999/html"/>

@{ if (string.IsNullOrWhiteSpace(Model.Input.StudySessionId)) return; }

<h4>Studying Session - Deck (@Html.DisplayFor(model => model.Input.DeckTitle))</h4>

<partial name="_ValidationStatusMessagePartial" for="StatusMessage" />

@{
    /*var prevDisabled = !Model.Data.EntityList.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.Data.EntityList.HasNextPage ? "disabled" : "";
    var progress = Model.Data.EntityList.PageIndex / Model.Data.EntityList.TotalPages;
    var questionIndex = Model.Data.EntityList.PageIndex;
    var questionTotal = Model.Data.EntityList.TotalPages;
    var displayRemember = Model.Input.Remembers == 0;*/

    var showReveal = Model.Input.ShowRevealButton ? "" : "hidden";
    var showAnwser = Model.Input.ShowAnwserText ? "" : "hidden";
}

<p>
    @*<a asp-page="./Create">Create New</a> |
    <a asp-page="./Details" asp-route-id="@Model.Input.Id">Details</a> |
    <a asp-page="./Delete" asp-route-id="@Model.Input.Id">Delete</a> |
    <a asp-page="./Index">Back to List</a>*@
</p>
<hr />

<div class="row align-items-center">
    <div class="row-cols-md-auto">
        <form method="post"
              asp-route-id="@Model.Input.StudySessionId">
            
            <input type="hidden" asp-for="Input.UserId"/>
            <input type="hidden" asp-for="Input.StudySessionId"/>
            <input type="hidden" asp-for="Input.DeckId"/>
            <input type="hidden" asp-for="Input.FlashcardId"/>
            <input type="hidden" asp-for="Input.FlashcardProgressId"/>

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="container align-content-center">
                <div class="card-deck mb-3 text-center">
                    <div class="card mb-4 box-shadow">
                        <div class="card-header">
                            <h5 class="my-0 font-weight-normal">Question 1 of 10</h5>
                        </div>
                        <div class="card-body">
                            @Model.Input.Question
                            <hr/>
                            @if (Model.Input.ShowAnwserText)
                            {
                                @Model.Input.Answer
                            }
                            @if (Model.Input.ShowRevealButton)
                            {
                                <input type="hidden" asp-for="Input.ShowAnwserText" value="true"/>
                                <input type="hidden" asp-for="Input.ShowRevealButton" value="false"/>
                                <input type="submit" asp-for="Input.Command" value="@StudyViewModelCommand.Reveal"
                                       class="btn btn-lg btn-block btn-outline-primary" />
                            }
                        </div>
                        <div class="card-footer">
                            @if (!Model.Input.ShowRevealButton)
                            {
                                <input type="submit" asp-for="Input.Command" value="@StudyViewModelCommand.Remember"
                                       class="btn btn-lg btn-block btn-outline-success" />
                                
                                <input type="submit" asp-for="Input.Command" value="@StudyViewModelCommand.Forgot"
                                       class="btn btn-lg btn-block btn-outline-danger" />
                            }
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
