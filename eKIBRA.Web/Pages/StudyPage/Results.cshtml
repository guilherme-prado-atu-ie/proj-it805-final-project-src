@page
@model eKIBRA.Web.Pages.StudyPage.ResultsModel

@{
    ViewData["Title"] = "Test Results";
}

<partial name="_ValidationAuthenticationCheckPartial"/>

<h4>Study Results</h4>

<partial name="_ValidationStatusMessagePartial" for="StatusMessage"/>

@{ if (string.IsNullOrWhiteSpace(Model.Data?.StudySessionId)) return; }

<p>
    <a asp-page="./Index">Back to List</a>
</p>
<hr/>
<div class="container mt-4">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">@Model.Data.Title</h2>
                    <p class="text-muted mb-0">@Model.Data.Description</p>
                    <small class="text-muted">
                        Completed: @Model.Data.CompletedDate?.ToString("dd MMM yyyy, HH:mm")
                    </small>
                </div>
                <div class="text-end">
                    @if (Model.Data.Status == StudySessionStatus.Completed)
                    {
                        <span class="badge bg-success fs-6">
                        <i class="fas fa-check-circle me-1"></i>Completed</span>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="card mb-4 shadow-sm border-1 bg-light">
        <div class="card-body text-center p-4">
            <div class="row align-items-center">
                <div class="col-md-1">
                </div>
                <div class="col-md-2">
                    <div class="score-circle mx-auto mb-3 mb-md-0">
                        <div class="score-text">
                            <div class="score-percentage">
                                <h3>@Model.Stats.MemoryRetention%</h3></div>
                            <small class="text-muted"><h6>Retention</h6></small>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-primary">
                            <h3>@Model.Stats.SumOfReveals</h3></div>
                        <span class="text-muted"><h6>Reveals</h6></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-success">
                            <h3>@Model.Stats.SumOfRemember</h3></div>
                        <span class="text-muted"><h6>Remembers</h6></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-danger">
                            <h3>@Model.Stats.SumOfForgot</h3></div>
                        <span class="text-muted"><h6>Forgot</h6></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-warning">
                            <h3>@Model.Stats.AvgRepetitionInterval</h3></div>
                        <span class="text-muted"><h6>Session SRM (days)</h6></span>
                    </div>
                </div>
                <div class="col-md-1">
                </div>
            </div>
            <div class="row">
                <div class="col col-md-12">
                    <hr/>
                </div>
            </div>
            <div class="row align-items-center">
                <div class="col-md-1">
                </div>
                <div class="col-md-2">
                    <div class="score-circle mx-auto mb-3 mb-md-0">
                        <div class="score-text">
                            <div class="score-percentage">
                                <h3>@Model.Stats.MemoryRetentionAcrossSessions%</h3></div>
                            <small class="text-muted"><h6>Retention<br>(in Previous Sessions)</h6></small>
                        </div>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-primary">
                            <h3>@Model.Stats.RevealsAcrossSessions</h3></div>
                        <span class="text-muted"><h6>Total of Reveals<br>(in Previous Sessions)</h6></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-success">
                            <h3>@Model.Stats.RemembersAcrossSessions</h3></div>
                        <span class="text-muted"><h6>Total of Remembers<br>(in Previous Sessions)</h6></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-danger">
                            <h3>@Model.Stats.ForgotAcrossSessions</h3></div>
                        <span class="text-muted"><h6>Total of Forgot<br>(in Previous Sessions)</h6></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="stat-item">
                        <div class="stat-number text-warning">
                            <h3>@Model.Stats.AvgNextRepetitionInterval</h3></div>
                        <span class="text-muted"><h6>Next SRM (days)</h6></span>
                    </div>
                </div>
                <div class="col-md-1">
                </div>
            </div>
        </div>
    </div>

    <!-- Performance Breakdown -->
    <div class="row mb-4">
        <div class="col-md-12">
            <!-- Question-by-Question Results -->
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">Question Details</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive" style="overflow-y: auto;">
                        <table class="table table-striped table-bordered table-hover table-sm">
                            <thead class="table-light sticky-top">
                            <tr>
                                <th class="text-center align-middle">#</th>
                                <th class="text-start align-middle">Question</th>
                                <th class="text-center align-middle">Level</th>
                                <th class="text-center align-middle">Reveals</th>
                                <th class="text-center align-middle">Forgot</th>
                                <th class="text-center align-middle">Reveals<br>(Previous)</th>
                                <th class="text-center align-middle">Remembers<br>(Previous)</th>
                                <th class="text-center align-middle">Forgot<br>(Previous)</th>
                                <th class="text-center align-middle">SRM</th>
                                <th class="text-center align-middle">Next SRM</th>
                                <th class="text-center align-middle">Result</th>
                            </tr>
                            </thead>
                            <tbody>
                            @for (var i = 0; i < Model.QuestionResults.Count; i++)
                            {
                                var result = Model.QuestionResults[i];
                                <tr>
                                    <td class="text-center align-middle"><strong>@(i + 1)</strong></td>
                                    <td class="text-start align-middle">
                                        <span class="question-preview" title="@result.QuestionText">
                                            @(result.QuestionText.Length > 50 ? result.QuestionText.Substring(0, 50) + "..." : result.QuestionText)
                                        </span>
                                    </td>
                                    @*<td class="text-start align-middle">
                                        <span class="@(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                            @result.RememberForgetSummary
                                        </span>
                                    </td>*@
                                    <td class="text-center align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.Level.ToString()
                                    </td>
                                    <td class="text-end align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.Reveal
                                    </td>
                                    <td class="text-end align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.Forgot
                                    </td>
                                    <td class="text-end align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.RevealsAcrossSessions
                                    </td>
                                    <td class="text-end align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.RemembersAcrossSessions
                                    </td>
                                    <td class="text-end align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.ForgotAcrossSessions
                                    </td>
                                    <td class="text-end align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.RepetitionInterval
                                    </td>
                                    <td class="text-end align-middle @(result.HasRememberAtFirst ? "text-success" : "text-danger")">
                                        @result.NextRepetitionInterval
                                    </td>
                                    <td class="text-center align-middle">
                                        @if (result.HasRememberAtFirst)
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" class="bi bi-check-lg text-success" viewBox="0 0 22 22">
                                                <path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/>
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-lg text-danger" viewBox="0 0 16 16">
                                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"/>
                                            </svg>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>